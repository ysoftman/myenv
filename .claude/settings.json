{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(make:*)",
      "Bash(xxd:*)",
      "Bash(air:*)",
      "WebSearch",
      "Bash(gh pr:*)",
      "Bash(ls:*)",
      "Bash(xargs cat:*)",
      "WebFetch(domain:github.com)",
      "Bash(go install:*)",
      "Bash(git log:*)",
      "Bash(fd:*)",
      "Bash(golangci-lint run:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'cat | bash /Users/ysoftman/.claude/statusline-command.sh 2>/dev/null'"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "plannotator@plannotator": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "language": "korean"
}
